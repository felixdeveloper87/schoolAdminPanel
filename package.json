{
  "name": "escola-admin",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @escola/api --filter @escola/web dev",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:migrate": "pnpm --filter @escola/api prisma:migrate",
    "db:seed": "pnpm --filter @escola/api prisma:seed"
  },
  "packageManager": "pnpm@9.12.0"
}
